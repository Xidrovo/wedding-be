{
  "functions": {
    "source": ".",
    "runtime": "nodejs20",
    "ignore": [
      "src",
      "node_modules",
      "test",
      "scripts",
      ".gitignore",
      "*.ts",
      "service-account.json"
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "emulators": {
    "firestore": {
      "port": 8080,
      "host": "127.0.0.1"
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  }
}
